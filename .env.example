# =============================================================================
# Azure Logs Forwarder - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control!!!

# General
LOG_LEVEL=WARNING  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ---------------------------------------------------------------------------
# Shared Azure settings
# ---------------------------------------------------------------------------

# Event Hub namespace FQDN
EVENTHUB_FQDN=myns.servicebus.windows.net

# Default starting position: @latest or -1 (from beginning of stream, in case of interruption this will make sure that you won't miss any logs)
EVENTHUB_STARTING_POSITION=-1

# Blob Storage for checkpoints (each forwarder needs its own container)
BLOB_ACCOUNT_URL=https://mystorage.blob.core.windows.net

# Graylog GELF HTTP endpoint
GRAYLOG_GELF_HTTP_URL=http://graylog.example.local:12201/gelf

# Default syslog severity for all forwarders (can be overridden per forwarder)
# 7=debug, 6=info, 5=notice, 4=warning, 3=error
GELF_LEVEL=6

# ---------------------------------------------------------------------------
# Azure Identity (uses DefaultAzureCredential)
# ---------------------------------------------------------------------------
# System Assigned Managed Identity: leave AZURE_CLIENT_ID empty
# User Assigned Managed Identity:   set AZURE_CLIENT_ID to the identity's client ID
AZURE_CLIENT_ID=
# Local development (Service Principal):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Forwarders
# ---------------------------------------------------------------------------
# Comma-separated list of forwarder names. Each name defines a separate
# Event Hub consumer with its own checkpoint container and log transformer.
#
# Per forwarder variables (NAME uppercased as prefix):
#   <NAME>_EVENTHUB_NAME        required  Event Hub name
#   <NAME>_CONSUMER_GROUP       optional  default: $Default
#   <NAME>_BLOB_CONTAINER       required  blob container for checkpoints
#   <NAME>_LOG_TYPE             optional  azure_firewall | azure_nsg | azure_waf | generic (default: generic)
#   <NAME>_GELF_HOSTNAME        optional  default: system hostname
#   <NAME>_GELF_LEVEL           optional  overrides GELF_LEVEL
#   <NAME>_STARTING_POSITION    optional  overrides EVENTHUB_STARTING_POSITION

FORWARDER_NAMES=firewall,nsg,waf

# -- Firewall --
# FIREWALL_EVENTHUB_NAME=firewall-logs
# FIREWALL_CONSUMER_GROUP=graylog-firewall
# FIREWALL_BLOB_CONTAINER=checkpoints-firewall
# FIREWALL_LOG_TYPE=azure_firewall
# FIREWALL_GELF_HOSTNAME=azure-fw

# -- NSG (Network Security Group flow logs) --
# NSG_EVENTHUB_NAME=nsg-logs
# NSG_CONSUMER_GROUP=graylog-nsg
# NSG_BLOB_CONTAINER=checkpoints-nsg
# NSG_LOG_TYPE=azure_nsg
# NSG_GELF_HOSTNAME=azure-nsg

# -- WAF (Application Gateway WAF) --
# WAF_EVENTHUB_NAME=waf-logs
# WAF_CONSUMER_GROUP=graylog-waf
# WAF_BLOB_CONTAINER=checkpoints-waf
# WAF_LOG_TYPE=azure_waf
# WAF_GELF_HOSTNAME=azure-waf

# ---------------------------------------------------------------------------
# Email Alerts (optional)
# ---------------------------------------------------------------------------
# Enabled when SMTP_HOST, SMTP_FROM and SMTP_TO are all set.

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=alerts@example.com
# SMTP_TO=admin@example.com,ops@example.com
# SMTP_SUBJECT=Azure Logs Forwarder - Error Alert
# SMTP_USERNAME=alerts@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=true                 # false to disable STARTTLS
# SMTP_LOG_LEVEL=ERROR              # Minimum level to email: DEBUG, INFO, WARNING, ERROR, CRITICAL
# SMTP_BATCH_INTERVAL=30            # Seconds between email batches
